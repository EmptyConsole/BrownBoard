{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2020"],
    "rootDir": "./src/electron",
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/electron/**/*"],
  "exclude": ["node_modules"]
}